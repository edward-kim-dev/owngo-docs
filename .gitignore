# =============================================================================
# OwnGoDocs — .gitignore
# 문서 저장소: docs/의 PDF/DOCX/XLSX 등 원본은 모두 추적 대상.
# 개인 설정·캐시·크레덴셜·OS 메타데이터만 제외.
# =============================================================================

# -----------------------------------------------------------------------------
# Obsidian (wiki/는 Obsidian vault로 사용)
# -----------------------------------------------------------------------------
# 사용자별 workspace·플러그인 데이터·캐시·개인 단축키 차이로 머지 충돌이 잦음.
# vault 단위(.obsidian/)와 vault 휴지통(.trash/)은 루트·하위 어디에 생겨도 제외.
.obsidian/
**/.obsidian/
.trash/
**/.trash/

# -----------------------------------------------------------------------------
# 크레덴셜 / 환경 변수 (CLAUDE.md 규정 — 커밋 금지)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
credentials.json
secrets.json

# -----------------------------------------------------------------------------
# OS 메타데이터
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
# 편집기 임시/스왑 파일
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.#*
\#*\#

# VSCode (사용자별) — 팀 공유할 설정이 생기면 !를 이용해 화이트리스트화
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# JetBrains
.idea/
*.iml

# -----------------------------------------------------------------------------
# Office 임시 잠금 파일 (원본 PDF·DOCX·XLSX는 추적하되, 열려 있는 동안 생기는
# 숨김 잠금 파일은 제외)
# -----------------------------------------------------------------------------
~$*
.~lock.*#

# -----------------------------------------------------------------------------
# 기타 빌드/임시 산출물
# -----------------------------------------------------------------------------
node_modules/
*.log
tmp/
.tmp/
